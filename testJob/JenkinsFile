pipeline {
    agent { label 'mac-laptop9' }
    parameters {
        string(name: 'CBL_VERSION', defaultValue: '4.0.0', description: 'CBL Version')
        string(name: 'CBL_DATASET_VERSION', defaultValue: '4.0', description: 'Dataset Version')
        string(name: 'CBL_PLATFORM', defaultValue: 'java', description: 'Platform')
        string(name: 'SGW_URL', defaultValue: '', description: 'Sync Gateway URL')
        string(name: 'PRIVATE_KEY_PATH', defaultValue: '', description: 'Path to SSH private key')
        string(name: 'TEST_TO_RUN', defaultValue: 'tests/test_api_scope_collection.py::TestLimitScopesCollections::test_limit_scopes_collections', description: 'Specific test to run')
    }
    environment {
        SCRIPT_DIR = 'environment'
        TESTS_DIR = 'tests'
        DOCKER_ENV_FILE = '.env'
    }
    stages {
        stage('Checkout Repository') {
            steps {
                git branch: 'tests/apiScopeColl', url: 'https://github.com/couchbaselabs/couchbase-lite-tests.git'
            }
        }
        stage('Start Docker Environment') {
            steps {
                script {
                    sh """
                    cd ${SCRIPT_DIR}
                    cp sample.env ${DOCKER_ENV_FILE}
                    docker compose down --rmi all
                    docker compose up -d
                    sleep 30
                    """
                }
            }
        }
        stage('Prepare Environment') {
            steps {
                script {
                    sh """
                    source ${SCRIPT_DIR}/prepare_env.sh
                    python3 -m venv venv
                    source venv/bin/activate
                    pip install -r ${SCRIPT_DIR}/aws/requirements.txt
                    """
                }
            }
        }
        stage('Run Setup Test') {
            steps {
                script {
                    if (params.PRIVATE_KEY_PATH?.trim()) {
                        sh "python3 ${SCRIPT_DIR}/setup_test.py ${params.CBL_PLATFORM} ${params.CBL_VERSION} ${params.SGW_URL} --private_key ${params.PRIVATE_KEY_PATH}"
                    } else {
                        sh "python3 ${SCRIPT_DIR}/setup_test.py ${params.CBL_PLATFORM} ${params.CBL_VERSION} ${params.SGW_URL}"
                    }
                }
            }
        }
        stage('Run Test') {
            steps {
                script {
                    sh """
                    source venv/bin/activate
                    pip install -r ${TESTS_DIR}/requirements.txt
                    pytest -v --no-header --config config.json ${params.TEST_TO_RUN}
                    deactivate
                    """
                }
            }
        }
    }
    post {
        always {
            script {
                sh "docker compose down"
            }
            archiveArtifacts artifacts: 'test-results/*', allowEmptyArchive: true
        }
        failure {
            echo "Test failed. Check logs for details."
        }
    }
}
