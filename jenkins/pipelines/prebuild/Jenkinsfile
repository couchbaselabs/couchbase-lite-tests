pipeline {
    agent none
    options {
        skipDefaultCheckout()
    }
    parameters {
        choice(
            name: 'TS_PLATFORM',
            choices: ['dotnet_windows', 'dotnet_macos', 'dotnet_ios', 'dotnet_android', 'jak_android', 'jak_desktop', 'jak_webservice', 'swift_ios', 'c_ios', 'c_android', 'c_linux_x86_64', 'c_macos', 'c_windows', 'js'],
            description: 'The test server platform to build'
        )
        string(
            name: 'CBL_VERSION',
            description: 'The version of CBL to use'
        )
        string(
            name: 'CBL_BUILD',
            description: 'The build of CBL to use'
        )
        booleanParam(
            name: 'FORCE',
            defaultValue: false,
            description: 'Build the test server even if it already exists for this platform and CBL version/build'
        )
    }
    stages {
        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.TS_PLATFORM || !params.CBL_VERSION) {
                        error("One or more required parameters are not set. Please set TS_PLATFORM, CBL_VERSION, CBL_BUILD.")
                    }
                    if(!params.CBL_BUILD) {
                        currentBuild.displayName = "${params.TS_PLATFORM} ${params.CBL_VERSION}"
                    } else {
                        currentBuild.displayName = "${params.TS_PLATFORM} ${params.CBL_VERSION}-${params.CBL_BUILD}"
                    }
                }
            }
        }
        stage("Determine Branch") {
            steps {
                script {
                    def match = (params.CBL_VERSION =~ /^(\d+)\.(\d+)/)[0]
                    if (!match) {
                        error "CBL_VERSION format is invalid: ${params.CBL_VERSION}"
                    }

                    def majorMinor = "${match[1]}.${match[2]}"
                    env.BUILD_BRANCH = "release/${majorMinor}"

                    // Check if e.g. release/3.2 exists in the repo
                    def apiUrl = "https://api.github.com/repos/couchbaselabs/couchbase-lite-tests/branches/${env.BUILD_BRANCH}"
                    def response = httpRequest(
                        url: apiUrl,
                        validResponseCodes: '200,404'
                    )

                    if (response.status != 200) {
                        env.BUILD_BRANCH = 'main'
                    }
                    echo "Build will come from branch ${env.BUILD_BRANCH}"
                }
            }
        }
        stage('Build') {
            agent {
                label getNodeForPlatform(params.TS_PLATFORM)
            }
            steps {
                cleanWs()

                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${env.BUILD_BRANCH}"]],
                    userRemoteConfigs: [[url: 'https://github.com/couchbaselabs/couchbase-lite-tests']]
                ])
                script {
                    def fullVersion
                    if (!params.CBL_BUILD) {
                        fullVersion = "${params.CBL_VERSION}"
                    } else {
                        fullVersion = "${params.CBL_VERSION}-${params.CBL_BUILD}"
                    }

                    def uploadFlag = params.FORCE ? "--upload" : "--ci"

                    withEnv(["FULL_CBL_VERSION=${fullVersion}"]) {
                        if (params.TS_PLATFORM.contains("ios")) {
                            withCredentials([string(credentialsId: "${env.NODE_NAME}-keychain-password", variable: 'KEYCHAIN_PASSWORD')]) {
                                sh 'security unlock-keychain -p ${KEYCHAIN_PASSWORD} ~/Library/Keychains/login.keychain-db'
                            }
                        }

                        if (params.TS_PLATFORM.contains("windows")) {
                            pwsh """
                                if ( Test-Path -Path ./jenkins/pipelines/prebuild/setup.psm1 ) {
                                    Import-Module ./jenkins/pipelines/prebuild/setup.psm1 -Force
                                } else {
                                    Import-Module ./jenkins/pipelines/shared/config.psm1 -Force
                                }

                                uv run --python 3.13 ./environment/aws/topology_setup/build_test_server.py \$env:TS_PLATFORM \$env:FULL_CBL_VERSION ${uploadFlag}
                            """
                        } else {
                            sh """#!/bin/bash -e
                                if [ -f jenkins/pipelines/prebuild/setup.sh ]; then
                                    source jenkins/pipelines/prebuild/setup.sh
                                else 
                                    source jenkins/pipelines/shared/config.sh
                                fi
                                
                                uv run --python 3.13 "environment/aws/topology_setup/build_test_server.py" $TS_PLATFORM $FULL_CBL_VERSION ${uploadFlag}
                            """
                        }
                    }
                }
            }
        }
    }
}

def getNodeForPlatform(platform) {
    if (platform.contains("windows")) {
        return 'e2e&&windows-host'
    } else if (platform.contains("linux")) {
        return 'e2e&&linux-host'
    } else {
        return 'e2e&&macos-host'
    }
}
