pipeline {
    agent none
    parameters {
        string(name: 'CBL_VERSION', defaultValue: '3.3.0', description: 'Couchbase Lite Version (build number will be fetched if not provided)')
        string(name: 'SGW_VERSION', defaultValue: '3.2.3', description: "The version of Sync Gateway to download")
        string(name: 'TS_DATASET_VERSION', defaultValue: '4.0', description: 'The version of the dataset to use on the test servers')
    }
    options {
        timeout(time: 150, unit: 'MINUTES')
    }
    stages {
        stage('Init') {
            steps {
                script {
                    if (params.CBL_VERSION == '') { error "CBL_VERSION is required" }
                    if (params.SGW_VERSION == '') { error "SGW_VERSION is required" }
                    currentBuild.displayName = "Dotnet CBL:${params.CBL_VERSION} (#${currentBuild.number})"
                    currentBuild.description = "SGW: ${params.SGW_VERSION}"
                }
            }
        }
        stage('Run Tests') {
            parallel {
                stage('Windows') {
                    agent { label 'mob-e2e-win-02' }
                    options {
                        lock('mob-e2e-win-02')
                    }
                    environment {
                        TS_ARTIFACTS_DIR = 'dotnet_windows'
                    }
                    steps {
                        echo "=== Run Dotnet Windows Tests"
                        timeout(time: 120, unit: 'MINUTES') {
                            powershell "jenkins\\pipelines\\QE\\dotnet\\run_test.ps1 -Version ${params.CBL_VERSION} -SgwVersion ${params.SGW_VERSION} -DatasetVersion ${params.TS_DATASET_VERSION}"
                        }
                        echo "=== Dotnet Windows Tests Complete"
                    }
                    post {
                        always {
                            echo "=== Teardown Dotnet Windows Tests"
                            timeout(time: 5, unit: 'MINUTES') {
                                powershell 'jenkins\\pipelines\\QE\\dotnet\\teardown.ps1'
                            }
                            archiveArtifacts artifacts: 'tests\\QE\\dotnet_windows\\**\\*', fingerprint: true, allowEmptyArchive: true
                            echo "=== Dotnet Windows Test Teardown Complete"
                        }
                    }
                }
            }
        }
    }
}