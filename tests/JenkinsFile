pipeline {
    agent { label 'mac-laptop9' }

    parameters {
        string(name: 'CBL_VERSION', defaultValue: '3.2.2', description: 'CBL Version')
        string(name: 'CBL_DATASET_VERSION', defaultValue: '3.2', description: 'Dataset Version')
        string(name: 'CBL_PLATFORM', defaultValue: 'java', description: 'Platform')
        string(name: 'SGW_URL', defaultValue: 'https://latestbuilds.service.couchbase.com/builds/latestbuilds/sync_gateway/3.2.3/16/couchbase-sync-gateway-enterprise_3.2.3-16_arm64.zip', description: "The url of Sync Gateway to download")
        string(name: 'TEST_TO_RUN', defaultValue: 'tests/test_api_scope_collection.py::TestLimitScopesCollections::test_limit_scopes_collections', description: 'Specific test to run')
    }
    environment {
        SCRIPT_DIR = 'environment'
        TESTS_DIR = 'tests'
    }
    stages {
        stage('Checkout Repository') {
            steps {
                git branch: 'tests/apiScopeColl', url: 'https://github.com/couchbaselabs/couchbase-lite-tests.git'
            }
        }
        stage('Prepare Environment') {
            steps {
                script {
                    sh """
                    python3 -m venv venv
                    source venv/bin/activate
                    pip install -r ${SCRIPT_DIR}/aws/requirements.txt
                    """
                }
            }
        }
        stage('Start Simulator') {
            steps {
                script {
                    if (params.CBL_PLATFORM == 'ios') {
                        sh """
                        echo "Starting iOS Simulator..."
                        xcrun simctl boot "iPhone 14"
                        """
                    } else if (params.CBL_PLATFORM == 'android') {
                        sh """
                        echo "Starting Android Emulator..."
                        emulator -avd Pixel_4_API_33 -no-window -no-audio -no-boot-anim &
                        sleep 30  # Wait for emulator to boot
                        adb wait-for-device
                        """
                    }
                }
            }
        }
        stage('Run Setup Test') {
            steps {
                script {
                    sh "python3 ${SCRIPT_DIR}/../jenkins/pipelines/dotnet/setup_test.py ${params.CBL_PLATFORM} ${params.CBL_VERSION}"
                }
            }
        }
        stage('Run Test') {
            steps {
                script {
                    sh """
                    source venv/bin/activate
                    pip install -r ${TESTS_DIR}/requirements.txt
                    pytest -v --no-header --config config.json ${params.TEST_TO_RUN}
                    deactivate
                    """
                }
            }
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'test-results/*', allowEmptyArchive: true
        }
        failure {
            echo "Test failed. Check logs for details."
        }
    }
}
